<Window x:Class="AbsenSholat.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AbsenSholat"
        mc:Ignorable="d"
        Title="Absen Sholat - Daftar"
        Height="500"
        Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar (left) with right drop shadow -->
        <Border Grid.Column="0" SnapsToDevicePixels="True" Margin="0,0,6,0">
            <Border.Effect>
                <DropShadowEffect Color="#44000000" Direction="0" ShadowDepth="8" BlurRadius="14" Opacity="0.25"/>
            </Border.Effect>
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#ed891f" Offset="0"/>
                        <GradientStop Color="#f09c43" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="20"
                            Orientation="Vertical"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <TextBlock Text="ABSENSI SHOLAT"
                               FontWeight="Bold"
                               FontSize="24"
                               Foreground="White"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="SMKN 2"
                               FontWeight="Bold"
                               FontSize="24"
                               Foreground="White"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="SINGOSARI"
                               FontWeight="Bold"
                               FontSize="24"
                               Foreground="White"/>
                </StackPanel>

                <Image Source="/AbsenSholat;component/Images/logosmk.png"
                       Grid.Row="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

                <Grid Grid.Row="2" Margin="10, 0, 10, 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Image Source="/AbsenSholat;component/Images/inobiru.png" HorizontalAlignment="Left" />
                    <Image Grid.Column="1" Source="/AbsenSholat;component/Images/inooren.png"  HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Registration Form (right) with rounded left corners -->
        <Border Grid.Column="1" Margin="34,40,40,40" CornerRadius="20,0,0,20">
            <Border.Background>
                <ImageBrush ImageSource="/AbsenSholat;component/Images/inorasi.png" Stretch="Fill" />
            </Border.Background>
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Daftar"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,30"/>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <!-- NIS -->
                    <Grid VerticalAlignment="Center" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="NIS:" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" />
                        <TextBox Style="{DynamicResource RoundedTextBoxStyle}" 
                                 Grid.Column="1" 
                                 Name="NisTextBox" 
                                 FontSize="14" 
                                 Padding="10" 
                                 Margin="5,0,0,0">
                        </TextBox>
                    </Grid>

                    <!-- EMAIL -->
                    <Grid VerticalAlignment="Center" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Email:" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" />
                        <TextBox Style="{DynamicResource RoundedTextBoxStyle}" 
                                 Grid.Column="1" 
                                 Name="EmailTextBox" 
                                 FontSize="14" 
                                 Padding="10" 
                                 Margin="5,0,0,0" 
                                 />
                    </Grid>

                    <!-- Password -->
                    <Grid VerticalAlignment="Center" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Kata Sandi:" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold" />
                        <Grid Margin="5,0,0,0" Grid.Column="1">
                            <TextBox Name="KataKunciTextBox"
                                     Style="{DynamicResource RoundedTextBoxStyle}"
                                     FontSize="14"
                                     Padding="10,10,40,10"
                                     Margin="0"
                                     Visibility="Collapsed" />
                            <PasswordBox
                                Name="KataKunciPasswordBox" 
                                FontSize="14" 
                                Style="{DynamicResource RoundedPasswordBoxStyle}"
                                Padding="10,10,40,10"/>
                            <Button Name="KataKunciToggleButton"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Width="36"
                                    Height="36"
                                    Cursor="Hand"
                                    Margin="0,0,2,0"
                                    Padding="0"
                                    Opacity="0.6">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter />
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Viewbox Width="20" Height="20">
                                    <Canvas Width="24" Height="24">
                                        <Path x:Name="EyePath" Fill="#666666" Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17a5,5 0 0,1 -5,-5a5,5 0 0,1 5,-5a5,5 0 0,1 5,5a5,5 0 0,1 -5,5M12,4.5C7,4.5 2.73,7.61 1,12c1.73,4.39 6,7.5 11,7.5s9.27,-3.11 11,-7.5c-1.73,-4.39 -6,-7.5 -11,-7.5Z" />
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </Grid>
                    </Grid>
                </StackPanel>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Margin="0,0,0,20" HorizontalAlignment="Center">
                    <Button x:Name="RegisterButton" 
                            Content="Daftar" 
                            FontSize="14" 
                            FontWeight="Bold"
                            Foreground="White"
                            Cursor="Hand"
                            HorizontalAlignment="Center"
                            Width="120">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFF9800" Offset="0"/>
                                <GradientStop Color="#FFFF9800" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border x:Name="border" 
                                        Background="{TemplateBinding Background}" 
                                        CornerRadius="8"
                                        RenderTransformOrigin="0.5,0.5"
                                        Padding="20 10">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="scale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="0.95"
                                                                     Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="scale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="0.95"
                                                                     Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="scale"
                                                                     Storyboard.TargetProperty="ScaleX"
                                                                     To="1"
                                                                     Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="scale"
                                                                     Storyboard.TargetProperty="ScaleY"
                                                                     To="1"
                                                                     Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Login Link -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <TextBlock Text="Sudah Punya Akun? " FontSize="12"/>
                        <Button x:Name="LoginButton" 
                                Content="Masuk" 
                                FontSize="12" 
                                FontWeight="SemiBold"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#FF2196F3"
                                Cursor="Hand"
                                Padding="2,0">
                            <Button.Template>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <TextBlock TextDecorations="Underline"><InlineUIContainer>
                                            <ContentPresenter/>
                                        </InlineUIContainer></TextBlock>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>