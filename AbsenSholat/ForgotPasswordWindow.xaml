<Window x:Class="AbsenSholat.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AbsenSholat"
        mc:Ignorable="d"
        Title="Absen Sholat - Lupa Kata Sandi"
        Height="500"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">

    <Window.Resources>
        <!-- Style for Rounded TextBox -->
        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="20">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar (Left) -->
        <Border Grid.Column="0">
            <Grid>
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#ed891f" Offset="0"/>
                        <GradientStop Color="#f09c43" Offset="1"/>
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header Text -->
                <StackPanel Margin="20,30,20,0">
                    <TextBlock Text="ABSENSI SHOLAT" FontWeight="Bold" FontSize="20" Foreground="White"/>
                    <TextBlock Text="SMKN 2" FontWeight="Bold" FontSize="20" Foreground="White"/>
                    <TextBlock Text="SINGOSARI" FontWeight="Bold" FontSize="20" Foreground="White"/>
                </StackPanel>

                <!-- School Logo -->
                <Image Grid.Row="1" 
                       Source="/AbsenSholat;component/Images/logosmk.png" 
                       Width="120" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"/>

                <!-- Mascots -->
                <Grid Grid.Row="2" Margin="10,0,10,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Image Grid.Column="0" Source="/AbsenSholat;component/Images/inobiru.png" Height="100" HorizontalAlignment="Left" Panel.ZIndex="1"/>
                    <Image Grid.Column="1" Source="/AbsenSholat;component/Images/inooren.png" Height="100" HorizontalAlignment="Right" Panel.ZIndex="1"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Main Content (Right) -->
        <Border Grid.Column="1" Background="#F9F9F9">
            <Grid>
                <!-- Watermark Background -->
                <Image Source="/AbsenSholat;component/Images/inorasi.png" 
                       Opacity="0.1" 
                       Stretch="Uniform" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       Width="300"/>

                <StackPanel VerticalAlignment="Center" Margin="50,0,50,0">
                    
                    <!-- Title -->
                    <TextBlock Text="LUPA KATA SANDI" 
                               FontSize="28" 
                               FontWeight="Black" 
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,40"
                               FontFamily="Arial"/>

                    <!-- NIS/Name Input -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Masukkan Nama:" FontWeight="Bold" Margin="10,0,0,5" FontSize="14"/>
                        <Grid>
                            <TextBox x:Name="NisTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"
                                     Height="45"
                                     TextChanged="Input_TextChanged"/>
                            
                            <!-- Placeholder -->
                            <TextBlock x:Name="NisPlaceholder"
                                       Text="NIS/NIP"
                                       Foreground="#999999"
                                       VerticalAlignment="Center"
                                       Margin="15,0,0,0"
                                       IsHitTestVisible="False"
                                       FontStyle="Italic"/>
                        </Grid>
                    </StackPanel>

                    <!-- Email Input -->
                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="Email:" FontWeight="Bold" Margin="10,0,0,5" FontSize="14"/>
                        <Grid>
                            <TextBox x:Name="EmailTextBox"
                                     Style="{StaticResource RoundedTextBoxStyle}"
                                     Height="45"
                                     TextChanged="Input_TextChanged"/>

                            <!-- Placeholder -->
                            <TextBlock x:Name="EmailPlaceholder"
                                       Text="Konfirmasi Email"
                                       Foreground="#999999"
                                       VerticalAlignment="Center"
                                       Margin="15,0,0,0"
                                       IsHitTestVisible="False"
                                       FontStyle="Italic"/>
                        </Grid>
                    </StackPanel>

                    <!-- Submit Button -->
                    <Button x:Name="SubmitButton"
                            Content="LANJUT"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="White"
                            Height="45"
                            Width="150"
                            HorizontalAlignment="Center"
                            Cursor="Hand"
                            Click="SubmitButton_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#FF9800" CornerRadius="22.5">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    
                    <!-- Back to Login -->
                    <Button x:Name="BackToLoginButton"
                            Content="Kembali ke Login"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="#2196F3"
                            Background="Transparent"
                            BorderThickness="0"
                            Margin="0,20,0,0"
                            Cursor="Hand"
                            Click="BackToLoginButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline" HorizontalAlignment="Center"/>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
