<Window x:Class="AbsenSholat.ScanQrWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AbsenSholat"
        mc:Ignorable="d"
        Title="Absen Sholat - Scan QR" 
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Header (Consistent with Dashboard) -->
        <Border Grid.Row="0" Background="#2196F3" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: App Name -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                    <!-- Logo Placeholder -->
                    <Border Width="40" Height="40" CornerRadius="20" Background="White" Margin="0,0,15,0">
                         <Image Source="/AbsenSholat;component/Images/logosmk.png" Stretch="Uniform"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="PRESENSI SHOLAT DIGITAL" 
                                   Foreground="White" 
                                   FontSize="18" 
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="CurrentDateText" 
                                   Text="SENIN, 22 JANUARI 2026" 
                                   Foreground="#E3F2FD" 
                                   FontSize="12" 
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Profile -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="18" Background="#E0E0E0" Margin="0,0,10,0">
                        <TextBlock x:Name="ProfileInitialText" 
                                   Text="M" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Center" 
                                   FontWeight="Bold"
                                   Foreground="#555"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="StudentNameBlock" 
                                   Text="M. MALIK..." 
                                   Foreground="White" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="StudentRoleBlock" 
                                   Text="Siswa" 
                                   Foreground="#BBDEFB" 
                                   FontSize="11"/>
                    </StackPanel>
                    
                     <Path Data="M0,0 L4,4 L8,0" Stroke="White" StrokeThickness="1.5" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                
                <TextBlock Text="Pindai Kode QR" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#111" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,5"/>
                
                <TextBlock Text="Arahkan kamera ke QR Kode" 
                           FontSize="14" 
                           Foreground="#666" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,30"/>

                <!-- Camera/Scan Container -->
                <Border Background="White" 
                        CornerRadius="10" 
                        Padding="20"
                        Width="450">
                    <Border.Effect>
                         <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#000" Opacity="0.1"/>
                    </Border.Effect>
                    
                    <StackPanel>
                        <!-- Camera Viewport Placeholder -->
                        <Border x:Name="CameraViewport" 
                                Background="Black" 
                                CornerRadius="8" 
                                Height="300" 
                                Margin="0,0,0,20"
                                Cursor="Hand"
                                MouseLeftButtonDown="OnCameraClick">
                            <Grid>
                                <!-- Default State -->
                                <Path x:Name="CameraIcon" 
                                      Data="M4,4H7L9,2H15L17,4H20A2,2 0 0,1 22,6V18A2,2 0 0,1 20,20H4A2,2 0 0,1 2,18V6A2,2 0 0,1 4,4M12,7A5,5 0 0,0 7,12A5,5 0 0,0 12,17A5,5 0 0,0 17,12A5,5 0 0,0 12,7M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z" 
                                      Fill="#333" 
                                      Stretch="Uniform" 
                                      Width="64" 
                                      Opacity="0.5"/>
                                
                                <!-- Scanning Line Animation (Hidden by default) -->
                                <Border x:Name="ScanLine" 
                                        Height="2" 
                                        Background="#00FF00" 
                                        VerticalAlignment="Top" 
                                        Visibility="Collapsed">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00FF00" BlurRadius="10" ShadowDepth="0"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Action Button -->
                        <Button x:Name="ScanButton"
                                Content="Mulai Scan"
                                Background="#0D47A1"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                Padding="15"
                                BorderThickness="0"
                                Click="OnStartScanClick">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </Button.Resources>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1565C0"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Background" Value="#B0BEC5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Border>
                
                <TextBlock Text="*Klik area hitam untuk simulasi scan jika kamera tidak tersedia" 
                           Foreground="#999" 
                           FontSize="10" 
                           Margin="0,10,0,0" 
                           HorizontalAlignment="Center"/>

            </StackPanel>
        </Grid>
    </Grid>
</Window>