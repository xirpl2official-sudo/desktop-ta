        private void OnQrDetected(string payload)
        {
            Dispatcher.Invoke(async () =>
            {
                if (_isProcessingQr || (DateTime.Now - _lastScanTime).TotalSeconds < 5) return;

                try
                {
                    _isProcessingQr = true;
                    Logger.Info("DashboardWindow", $"QR Code detected: {payload}");

                    // Validate Payload
                    var validation = QrPayloadValidator.Validate(payload);

                    if (!validation.IsValid)
                    {
                        // Invalid QR handling (optional: show toast)
                        Logger.Warning("DashboardWindow", $"Invalid QR: {validation.ErrorMessage}");
                        // Uncomment to show alert for invalid QR
                        // MessageBox.Show(validation.ErrorMessage, "QR Tidak Valid", MessageBoxButton.OK, MessageBoxImage.Warning);
                        return;
                    }

                    // Success - Valid attendance QR
                    _lastScanTime = DateTime.Now;
                    
                    // Stop camera temporarily to indicate success capture
                    // _cameraService.StopCamera(); // Optional

                    // Simulate API Call
                    // var request = QrPayloadValidator.BuildApiRequest(validation, _siswa?.Nis ?? "000");
                    // await _apiClient.PostAbsensiAsync(request); 

                    // Show Success Message
                    Logger.Success("DashboardWindow", $"Attendance recorded: {validation.JenisSalat} for {_siswa?.NamaSiswa}");
                    
                    MessageBoxResult result = MessageBox.Show(
                        $"Absensi {validation.JenisSalat} berhasil dicatat!\nWaktu: {DateTime.Now:HH:mm}\nLokasi: {validation.Masjid}", 
                        "Absensi Berhasil", 
                        MessageBoxButton.OK, 
                        MessageBoxImage.Information);

                    // Resume scanning if needed
                }
                catch (Exception ex)
                {
                    Logger.Error("DashboardWindow", "Error processing QR", ex);
                    MessageBox.Show($"Gagal memproses QR: {ex.Message}", "Error", MessageBoxButton.OK, MessageBoxImage.Error);
                }
                finally
                {
                    // Add delay before allowing next scan to prevent double processing
                    await System.Threading.Tasks.Task.Delay(2000);
                    _isProcessingQr = false;
                }
            });
        }

        private void DisplayStudentInfo()
        {
            if (_siswa != null)
            {
                // Sidebar
                string nameParts = _siswa.NamaSiswa?.Split(' ')[0]?.ToUpper() ?? "SISWA";
                if (!string.IsNullOrEmpty(_siswa.NamaSiswa) && _siswa.NamaSiswa.Contains(" "))
                {
                    var parts = _siswa.NamaSiswa.Split(' ');
                    nameParts = $"{parts[0].Substring(0, 1).ToUpper()} {parts[1].Substring(0, 1).ToUpper()}";
                    if (parts.Length > 2)
                        nameParts = $"{parts[0].Substring(0, 1).ToUpper()} {parts[1]}...".ToUpper();
                }
                
                SidebarName.Text = nameParts;
                SidebarInitials.Text = !string.IsNullOrEmpty(_siswa.NamaSiswa) ? _siswa.NamaSiswa.Substring(0, 1).ToUpper() : "S";
            }
        }

        private void StartClock()
        {
            _timer = new DispatcherTimer();
            _timer.Interval = TimeSpan.FromMinutes(1);
            _timer.Tick += (s, e) => LoadSchedule();
            _timer.Start();
        }

        private async void LoadData()
        {
            try
            {
                // Load Statistics from /statistics endpoint
                var statsResponse = await _apiClient.GetStatisticsAsync();
                if (statsResponse?.Data != null)
                {
                    TotalAbsensiText.Text = statsResponse.Data.TotalAbsenHariIni.ToString();
                    KehadiranText.Text = statsResponse.Data.TotalKehadiranHariIni.ToString();
                    // Stats endpoint doesn't return TotalAlpha, will get from History
                    // PersentaseText.Text = $"{statsResponse.Data.PersentaseKehadiran:0}%";
                }

                // Load History
                var historyResponse = await _apiClient.GetHistorySiswaAsync(0);
                if (historyResponse?.Data != null)
                {
                    // Update Total Alpha from History Statistics
                    if (historyResponse.Data.Statistik != null)
                    {
                        TotalAlphaText.Text = historyResponse.Data.Statistik.TotalAlpha.ToString();
                    }

                    // Update History Grid
                    if (historyResponse.Data.Absensi != null)
                    {
                        HistoryGrid.ItemsSource = historyResponse.Data.Absensi;
                    }
                }
            }
            catch (Exception ex)
            {
                // Silently fail or log for dashboard
            }

            LoadSchedule();
        }

        private void LoadSchedule()
        {
            var now = DateTime.Now.TimeOfDay;
            var schedule = new List<PrayerScheduleItem>();
            bool isPrayerTime = false;
            string activePrayerName = "";

            // Definisikan Jadwal (Contoh Hardcoded sesuai gambar)
            // Dhuha 07.00 - 08.00
            // Dhuhur 12.00 - 13.00 (Jumat mungkin beda, tapi kita samakan dulu)
            // Ashar 15.00 - 16.00

            var prayers = new[]
            {
                new { Name = "Dhuha", Start = new TimeSpan(6, 30, 0), End = new TimeSpan(9, 0, 0) },
                new { Name = "Dhuhur", Start = new TimeSpan(11, 30, 0), End = new TimeSpan(13, 0, 0) },
                new { Name = "Ashar", Start = new TimeSpan(15, 0, 0), End = new TimeSpan(16, 30, 0) },
                new { Name = "Maghrib", Start = new TimeSpan(17, 30, 0), End = new TimeSpan(18, 30, 0) }
            };

            foreach (var p in prayers)
            {
                var item = new PrayerScheduleItem
                {
                    Name = p.Name,
                    TimeRange = $"{p.Start:hh\\:mm} - {p.End:hh\\:mm} WIB"
                };

                if (now > p.End)
                {
                    item.StatusText = "Selesai";
                    item.StatusBackground = "#E8F5E9"; // Light Green
                    item.StatusForeground = "#4CAF50"; // Green
                    item.BorderColor = "#4CAF50";
                    item.BackgroundColor = "#F1F8E9";
                }
                else if (now >= p.Start && now <= p.End)
                {
                    item.StatusText = "Berlangsung";
                    item.StatusBackground = "#FFF3E0"; // Light Orange
                    item.StatusForeground = "#FF9800"; // Orange
                    item.BorderColor = "#FF9800";
                    item.BackgroundColor = "#FFF8E1";
                    
                    isPrayerTime = true;
                    activePrayerName = p.Name;
                }
                else
                {
                    item.StatusText = "Akan Datang";
                    item.StatusBackground = "#E3F2FD"; // Light Blue
                    item.StatusForeground = "#2196F3"; // Blue
                    item.BorderColor = "#2196F3";
                    item.BackgroundColor = "#F5F5F5";
                }

                schedule.Add(item);
            }

            PrayerScheduleList.ItemsSource = schedule;

            // Manage Alert Banner
            if (isPrayerTime)
            {
                PrayerAlertBanner.Visibility = Visibility.Visible;
                AlertTitleText.Text = $"Waktu Sholat {activePrayerName} !";
            }
            else
            {
                PrayerAlertBanner.Visibility = Visibility.Collapsed;
            }
        }

