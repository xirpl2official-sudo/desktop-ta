        protected override void OnClosed(EventArgs e)
        {
            Logger.Info("DashboardWindow", "Window closing, cleaning up resources...");
            
            // Stop timers
            _timer?.Stop();
            _scanAnimationTimer?.Stop();
            
            // Clean up camera
            if (_isCameraActive)
            {
                _cameraService?.StopCamera();
            }
            _cameraService?.Dispose();
            
            Logger.Info("DashboardWindow", "Cleanup complete");
            base.OnClosed(e);
        }
