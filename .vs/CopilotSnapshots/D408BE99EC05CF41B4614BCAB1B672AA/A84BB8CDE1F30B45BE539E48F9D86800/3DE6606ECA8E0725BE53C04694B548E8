        private void ShowPage(string pageName)
        {
            Logger.Info("Navigation", $"Switching to page: {pageName}");
            _currentPage = pageName;

            // Stop camera when leaving scan page
            if (pageName != "absen" && _isCameraActive)
            {
                Logger.Info("Camera", "Stopping camera due to page navigation");
                StopCamera();
            }

            // Hide all pages
            HomePageScroll.Visibility = Visibility.Collapsed;
            ScanQRScroll.Visibility = Visibility.Collapsed;
            ProfilePageScroll.Visibility = Visibility.Collapsed;

            // Show selected page
            switch (pageName)
            {
                case "home":
                    HomePageScroll.Visibility = Visibility.Visible;
                    Logger.Debug("Navigation", "Home page displayed");
                    break;
                case "absen":
                    ScanQRScroll.Visibility = Visibility.Visible;
                    Logger.Debug("Navigation", "Scan QR page displayed");
                    break;
                case "profile":
                    ProfilePageScroll.Visibility = Visibility.Visible;
                    LoadProfileData();
                    Logger.Debug("Navigation", "Profile page displayed");
                    break;
            }
        }

