        private void LoadProfileData()
        {
            if (_siswa != null)
            {
                TxtNis.Text = _siswa.Nis ?? "N/A";
                TxtNama.Text = _siswa.NamaSiswa ?? "";
                TxtKelas.Text = $"{_siswa.Kelas} {_siswa.Jurusan}" ?? "";
                TxtEmail.Text = _siswa.NamaSiswa ?? "";
                
                // Set Jenis Kelamin
                if (!string.IsNullOrEmpty(_siswa.jk))
                {
                    if (_siswa.jk.ToLower() == "l" || _siswa.jk.ToLower() == "laki-laki")
                        CmbJk.SelectedIndex = 0;
                    else
                        CmbJk.SelectedIndex = 1;
                }
            }
            
            // Set all fields to read-only since edit functionality is removed
            TxtNama.IsReadOnly = true;
            CmbJk.IsEnabled = false;
            TxtKelas.IsReadOnly = true;
            TxtEmail.IsReadOnly = true;
            
            TxtNama.Background = new SolidColorBrush(Color.FromRgb(245, 245, 245));
            TxtKelas.Background = new SolidColorBrush(Color.FromRgb(245, 245, 245));
            TxtEmail.Background = new SolidColorBrush(Color.FromRgb(245, 245, 245));
        }

