        private void StartCamera()
        {
            try
            {
                Logger.Info("Camera", "Starting camera...");
                CameraStatusText.Text = "Memulai kamera...";
                
                // Show camera UI
                CameraIcon.Visibility = Visibility.Collapsed;
                CameraImage.Visibility = Visibility.Visible;
                ScanButton.IsEnabled = false;
                ScanButton.Content = "📷 Memulai...";
                StopCameraButton.Visibility = Visibility.Visible;
                
                // Start camera with the window handle
                bool started = _cameraService.StartCamera(_windowHandle, 440, 360, 0);
                
                if (started)
                {
                    _isCameraActive = true;
                    _isScanning = true;
                    ScanButton.Content = "📷 Kamera Aktif";
                    CameraStatusText.Text = "Kamera aktif - Arahkan ke QR Code";
                    
                    // Start scan line animation
                    StartScanAnimation();
                    
                    Logger.Success("Camera", "Camera started successfully");
                }
                else
                {
                    Logger.Error("Camera", "Failed to start camera");
                    CameraStatusText.Text = "Gagal memulai kamera";
                    ScanButton.IsEnabled = true;
                    ScanButton.Content = "📷 Mulai Scan";
                    StopCameraButton.Visibility = Visibility.Collapsed;
                    CameraIcon.Visibility = Visibility.Visible;
                    CameraImage.Visibility = Visibility.Collapsed;
                    
                    MessageBox.Show("Tidak dapat mengakses kamera. Pastikan kamera tersedia dan tidak digunakan aplikasi lain.", 
                                    "Kamera Tidak Tersedia", 
                                    MessageBoxButton.OK, 
                                    MessageBoxImage.Warning);
                }
            }
            catch (Exception ex)
            {
                Logger.Error("Camera", "Exception starting camera", ex);
                MessageBox.Show($"Error: {ex.Message}", "Error", MessageBoxButton.OK, MessageBoxImage.Error);
                ResetCameraUI();
            }
        }

        private void StopCamera()
        {
            try
            {
                Logger.Info("Camera", "Stopping camera...");
                
                _cameraService.StopCamera();
                _isCameraActive = false;
                _isScanning = false;
                
                StopScanAnimation();
                ResetCameraUI();
                
                Logger.Success("Camera", "Camera stopped successfully");
            }
            catch (Exception ex)
            {
                Logger.Error("Camera", "Exception stopping camera", ex);
            }
        }

        private void ResetCameraUI()
        {
            CameraImage.Visibility = Visibility.Collapsed;
            CameraIcon.Visibility = Visibility.Visible;
            ScanButton.IsEnabled = true;
            ScanButton.Content = "📷 Mulai Scan";
            StopCameraButton.Visibility = Visibility.Collapsed;
            CameraStatusText.Text = "Klik 'Mulai Scan' untuk membuka kamera";
            ScanLine.Visibility = Visibility.Collapsed;
        }

        private void StartScanAnimation()
        {
            Logger.Debug("Animation", "Starting scan line animation");
            ScanLine.Visibility = Visibility.Visible;
            
            _scanAnimationTimer = new DispatcherTimer();
            _scanAnimationTimer.Interval = TimeSpan.FromMilliseconds(20);
            double y = 0;
            bool goingDown = true;
            
            _scanAnimationTimer.Tick += (s, ev) =>
            {
                if (goingDown) y += 4; else y -= 4;
                if (y > 340) goingDown = false;
                if (y < 0) goingDown = true;
                
                ScanLine.Margin = new Thickness(0, y, 0, 0);
            };
            _scanAnimationTimer.Start();
        }

        private void StopScanAnimation()
        {
            Logger.Debug("Animation", "Stopping scan line animation");
            _scanAnimationTimer?.Stop();
            ScanLine.Visibility = Visibility.Collapsed;
        }

