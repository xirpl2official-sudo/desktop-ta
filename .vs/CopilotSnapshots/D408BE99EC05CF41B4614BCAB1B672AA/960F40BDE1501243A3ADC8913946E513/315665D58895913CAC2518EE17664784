<Window x:Class="AbsenSholat.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AbsenSholat"
        mc:Ignorable="d"
        Title="Absen Sholat - Profil" 
        Height="800"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F0F4F8">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2196F3" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: App Name -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="PRESENSI SHOLAT DIGITAL" 
                               Foreground="White" 
                               FontSize="18" 
                               FontWeight="Bold"/>
                    <TextBlock x:Name="CurrentDateText" 
                               Text="DHUHA, DHUHUR, JUMAT" 
                               Foreground="#E3F2FD" 
                               FontSize="12" 
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Right: Profile -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="18" Background="#E0E0E0" Margin="0,0,10,0">
                        <TextBlock x:Name="HeaderInitials" 
                                   Text="M" 
                                   VerticalAlignment="Center" 
                                   HorizontalAlignment="Center" 
                                   FontWeight="Bold"
                                   Foreground="#555"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="HeaderName" 
                                   Text="M. MALIK..." 
                                   Foreground="White" 
                                   FontSize="14" 
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="HeaderRole" 
                                   Text="Siswa" 
                                   Foreground="#BBDEFB" 
                                   FontSize="11"/>
                    </StackPanel>
                    
                    <Path Data="M0,0 L4,4 L8,0" Stroke="White" StrokeThickness="1.5" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,30">
                
                <!-- Page Title Area -->
                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Back Button -->
                    <Button Grid.Column="0" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Margin="0,0,20,0"
                            Click="OnBackClick"
                            Cursor="Hand">
                        <Path Data="M20,11 H7.83 L13.42,5.41 L12,4 L4,12 L12,20 L13.41,18.59 L7.83,13 H20 V11 Z" 
                              Fill="#333" 
                              Stretch="Uniform" 
                              Width="24" 
                              Height="24"/>
                    </Button>

                    <!-- Titles -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Pengaturan Akun" FontSize="24" FontWeight="Bold" Foreground="#222"/>
                        <TextBlock Text="kelola informasi akun anda" FontSize="14" Foreground="#666"/>
                    </StackPanel>
                </Grid>

                <!-- Profile Form -->
                <StackPanel>
                    <!-- Avatar Section -->
                    <Grid HorizontalAlignment="Left" Margin="0,0,0,30">
                        <Ellipse Width="100" Height="100" Fill="#E0E0E0"/>
                        <Path Data="M12,12 c2.21,0 4,-1.79 4,-4 s-1.79,-4 -4,-4 s-4,1.79 -4,4 s1.79,4 4,4 z M12,14 c-2.67,0 -8,1.34 -8,4 v2 h16 v-2 c0,-2.66 -5.33,-4 -8,-4 z" 
                              Fill="#BDBDBD" 
                              Stretch="Uniform" 
                              Width="60" 
                              Height="60"
                              HorizontalAlignment="Center" 
                              VerticalAlignment="Center"/>
                        <TextBlock Text="Foto Profil" 
                                   Foreground="Black" 
                                   FontSize="16" 
                                   FontWeight="SemiBold" 
                                   Margin="120,10,0,0" 
                                   VerticalAlignment="Top"/>
                        
                        <!-- Edit Icon Mini -->
                         <Border Background="Transparent" Width="20" Height="20" Margin="80,70,0,0">
                            <Path Data="M3,17.25V21h3.75L17.81,9.94l-3.75-3.75L3,17.25zM20.71,7.04c0.39-0.39,0.39-1.02,0-1.41l-2.34-2.34 c-0.39-0.39-1.02-0.39-1.41,0l-1.83,1.83l3.75,3.75L20.71,7.04z"
                                  Fill="#5066FF" 
                                  Stretch="Uniform"/>
                        </Border>
                    </Grid>

                    <!-- Form Fields -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- NIS -->
                            <RowDefinition Height="Auto"/> <!-- Nama -->
                            <RowDefinition Height="Auto"/> <!-- JK & Kelas -->
                            <RowDefinition Height="Auto"/> <!-- Email -->
                            <RowDefinition Height="Auto"/> <!-- Buttons -->
                        </Grid.RowDefinitions>

                        <!-- NIS -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="NIS" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtNis" 
                                     Text="7803/1148.063" 
                                     Padding="10" 
                                     Background="White" 
                                     BorderThickness="0"
                                     IsReadOnly="True"
                                     Foreground="#555">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>

                        <!-- Nama Lengkap -->
                        <StackPanel Grid.Row="1" Margin="0,0,0,20">
                            <TextBlock Text="Nama lengkap" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtNama" 
                                     Text="Ravel" 
                                     Padding="10" 
                                     Background="White" 
                                     BorderThickness="0">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>

                        <!-- JK & Kelas -->
                        <Grid Grid.Row="2" Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Jenis Kelamin" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="CmbJk" Padding="10" Background="White" BorderThickness="0" Height="40">
                                    <ComboBoxItem Content="Laki-laki"/>
                                    <ComboBoxItem Content="Perempuan"/>
                                    <ComboBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Kelas/Jurusan" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <TextBox x:Name="TxtKelas" 
                                         Text="11 RPL 2" 
                                         Padding="10" 
                                         Background="White" 
                                         BorderThickness="0">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                            </StackPanel>
                        </Grid>

                        <!-- Email -->
                        <StackPanel Grid.Row="3" Margin="0,0,0,40">
                            <TextBlock Text="E-mail" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtEmail" 
                                     Text="jurusann@gamil.com" 
                                     Padding="10" 
                                     Background="White" 
                                     BorderThickness="0">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <TextBlock Text="Mengubah Email ?" 
                                       Foreground="#333" 
                                       FontSize="11" 
                                       Margin="0,5,0,0" 
                                       Cursor="Hand"
                                       MouseLeftButtonDown="OnChangeEmailClick"/>
                        </StackPanel>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Simpan Perubahan" 
                                    Background="White" 
                                    Foreground="Black" 
                                    FontWeight="Bold"
                                    Padding="20,12" 
                                    Margin="0,0,15,0"
                                    BorderThickness="0"
                                    Click="OnSaveClick">
                                <Button.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="#E0E0E0" Opacity="0.5"/>
                                </Button.Effect>
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>

                            <Button Content="Batal" 
                                    Background="White" 
                                    Foreground="Black" 
                                    FontWeight="Bold"
                                    Padding="30,12" 
                                    BorderThickness="0"
                                    Click="OnCancelClick">
                                <Button.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Direction="270" Color="#E0E0E0" Opacity="0.5"/>
                                </Button.Effect>
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>

                    </Grid>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>